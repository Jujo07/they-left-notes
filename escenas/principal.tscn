note_text = "\"La cabaña estaba vacía. Encontré más notas dentro, de alguien que estuvo aquí antes que yo. Llevaba semanas atrapado. Decía que la salida está al este, pasando el río seco. Esta noche he escuchado algo fuera. No me he asomado.\""

[node name="Area3D4" parent="." unique_id=921803863 instance=ExtResource("23_ihkm2")]
transform = Transform3D(0.39769045, 0, 0.04292212, 0, 0.39999998, 0, -0.04292212, 0, 0.39769045, 27.151733, 1.0512307, -3.716629)
note_text = "Este intentó correr. Le dije 'shhh, él no quiere verte así'. Lo arreglé para que tú no sufras al verlo."

[node name="Area3D3" parent="." unique_id=1491836309 instance=ExtResource("23_ihkm2")]
